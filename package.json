{
  "name": "opencode-subagent-router",
  "version": "1.0.5",
  "description": "Dynamic sub-agent model router for OpenCode - cost-optimized model selection with escalation and guardrails",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "lib/",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ashutoshsinghpr7/opencode-subagent-router"
  },
  "homepage": "https://github.com/ashutoshsinghpr7/opencode-subagent-router#readme",
  "bugs": {
    "url": "https://github.com/ashutoshsinghpr7/opencode-subagent-router/issues"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.11",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "subagent-router",
    "model-router",
    "cost-optimization",
    "sub-agent"
  ],
  "license": "MIT",
  "author": "Ace",
  "dependencies": {
    "tsx": "^4.22.4"
  }
}
